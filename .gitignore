# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
dist/
build/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Secrets / credentials
.env
*.pem
*-service-account*.json
gh_token*

# Raw connector caches (re-fetchable; never committed)
data/raw/
data/**/.cache/
data/corpus/**/.git/
data/**/*.tmp

# HYBRID STORAGE MODEL:
#   GitHub  = code + normalized catalog (data/catalog/*.jsonl) — the lean, searchable
#             index. `git pull` here is fast.
#   HF      = the COMPLETE hard-copy corpus (all sources + writeups, text AND binary)
#             at own2pwn-fr/ctfhoard-corpus — itself a git(-LFS) repo, so
#             `git clone` the dataset gives you everything in one pull.
# The whole materialized corpus lives under data/corpus/ locally and is published to
# HF via `ctfhoard publish-hf`; it is NOT tracked on GitHub (would be hundreds of GB).
data/corpus/

# Operational state (regenerable): discovery list + mirror resume manifest + staging
data/discovered_repos.jsonl
data/mirror_state.jsonl
data/staging/

# Per-repo catalog shards are published to HF during the marathon (dataset is
# self-describing). GitHub gets periodic consolidated catalog snapshots instead of
# thousands of live per-repo commits.
data/catalog/
data/staging_batch/
