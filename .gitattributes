# Hybrid storage model: GitHub holds only TEXT (code, writeups, catalog); heavy
# binaries live on the Hugging Face dataset (own2pwn-fr/ctfhoard-corpus), not here.
# So there is no Git LFS on the GitHub side — binaries under data/corpus/ are
# gitignored (see .gitignore). Catalog and corpus text stay diff-friendly.
data/catalog/**  text
data/corpus/**   text=auto
